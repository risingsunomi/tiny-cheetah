# Tiny Cheetah environment defaults
# Copy this file to `.env` and fill in the values you need. Leave entries blank
# to fall back to the application's built-in defaults.

# ---------------------------------------------------------------------------
# Runtime and chat behaviour
# ---------------------------------------------------------------------------
TC_OFFLINE_MODE=               # Set to true to prevent network downloads in the UI
TC_CHAT_MODEL=                 # Default chat model (HF repo or local name)
TC_LLM_BACKEND=torch           # LLM backend for chat UI: tinygrad or torch
TC_TORCH_DEVICE=cpu           # Preferred torch device (cpu, cuda, mps)
TC_TINYGRAD_DEVICE=METAL      # Preferred tinygrad device (CPU, CUDA, METAL, etc.)
TC_DEVICE=                    # Legacy fallback device env if backend-specific env is unset
TC_LOG_DIR=                    # Directory for runtime logs (default: ./logs)

# Sampler overrides when loading generation_config.json (optional)
TC_TEMP=
TC_TOP_K=
TC_TOP_P=
TC_REPETITION_PENALTY=
TC_MAX_SEQ_LEN=               # Override max sequence length from model config
TC_MAX_RESP_LEN=              # Chat response reserve tokens before history trim

# Hugging Face authentication token (optional)
HF_TOKEN=

# ---------------------------------------------------------------------------
# Agent defaults and memory guard
# ---------------------------------------------------------------------------
TC_AGENT_NAME=                 # Default agent name shown in Agent Config
TC_AGENT_INSTRUCTIONS=         # Default agent instructions
TC_AGENT_ENDLESS_MODE=false    # Ignore end_run until you manually stop the agent
TC_AGENT_MAX_STEPS=10          # Max loop iterations when Endless Mode is off
TC_AGENT_MAX_RESP_LEN=256      # Reserved response budget for agent prompt building
TC_AGENT_MAX_MEMORY_RECOVERIES=2        # Recovery attempts before stopping on memory pressure
TC_AGENT_MEMORY_TRIM_KEEP_MESSAGES=4    # Number of recent messages to keep when compacting history

TC_MEM_MAX_PERCENT=92          # Stop/recover if RAM usage reaches this percent
TC_SWAP_MAX_PERCENT=90         # Stop/recover if swap usage reaches this percent
TC_SWAP_ONLY_ABORT_PERCENT=99  # Abort on swap alone only at this higher emergency threshold
TC_MEM_MIN_AVAILABLE_GB=0.75   # Stop/recover if available RAM drops below this GiB threshold

# ---------------------------------------------------------------------------
# Training defaults used by the TUI/CLI
# ---------------------------------------------------------------------------
TC_TRAINING_MODEL_ID=
TC_TRAINING_CUSTOM_MODEL_ID=
TC_TRAINING_TOKENIZER_ID=
TC_TRAINING_TOKENIZER_FILE=
TC_TRAINING_CONFIG_PATH=
TC_TRAINING_GENERATION_CONFIG_PATH=
TC_TRAINING_WEIGHTS_DIR=
TC_TRAINING_DATA_PATH=
TC_TRAINING_DATASET_ID=
TC_TRAINING_DATASET_CACHE_DIR=
TC_TRAINING_MAX_DATASET_ENTRIES=

# Hyperparameters and execution options
TC_TRAINING_SEQ_LENGTH=
TC_TRAINING_BATCH_SIZE=
TC_TRAINING_EPOCHS=
TC_TRAINING_LR=
TC_TRAINING_DEVICE=
TC_TRAINING_GRADIENT_ACCUMULATION=
TC_TRAINING_SAVE_DIR=

# Boolean toggles accept true/false/1/0/yes/no
TC_TRAINING_FROM_SCRATCH=
TC_TRAINING_FINETUNE=
